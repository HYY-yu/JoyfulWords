# API 配置
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# 应用配置
PORT=8190
NEXT_PUBLIC_APP_URL=http://localhost:8190

# === Grafana Faro / OpenTelemetry 配置 ===
# 服务名称 (Next.js server spans)
OTEL_SERVICE_NAME=joyful-words-frontend
OTEL_SERVICE_NAMESPACE=joyfulwords
  
# Next.js OTel 详细日志 (仅开发环境)
NEXT_OTEL_VERBOSE=1

# Next.js server traces OTLP collector endpoint
# Grafana Cloud: 使用 Grafana Cloud OTLP endpoint, 并通过 OTEL_EXPORTER_OTLP_HEADERS 设置认证头
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-<region>.grafana.net/otlp
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(instance_id:token)>
OTEL_PROPAGATE_TRACE_URLS=https://api.joyword.link

# === 客户端追踪配置 ===
# 启用客户端追踪 (浏览器端)
NEXT_PUBLIC_ENABLE_TELEMETRY=true

# Grafana Frontend Observability Faro collector URL
NEXT_PUBLIC_FARO_URL=https://faro-collector-prod-<region>.grafana.net/collect/<source-id>
NEXT_PUBLIC_FARO_APP_NAME=joyful-words-frontend
NEXT_PUBLIC_FARO_APP_NAMESPACE=joyfulwords
NEXT_PUBLIC_FARO_APP_VERSION=production
NEXT_PUBLIC_FARO_PROPAGATE_TRACE_URLS=https://api.joyword.link

# === 功能开关配置 ===
# doing: 开发中,显示 Coming Soon 页面
# show: 已上线,显示完整功能
NEXT_PUBLIC_FEATURE_IMAGE_GENERATION=show
NEXT_PUBLIC_FEATURE_KNOWLEDGE_CARDS=doing
NEXT_PUBLIC_FEATURE_SEO_GEO=doing

# === Cookie Banner 配置 ===
# 在所有环境启用 Cookie Banner (包括开发环境)
NEXT_PUBLIC_ENABLE_COOKIE_BANNER=true

# === 产品分析配置 ===
# 启用 PostHog 产品分析。实际采集仍受 Cookie Banner 的 analytics 同意控制。
NEXT_PUBLIC_ENABLE_PRODUCT_ANALYTICS=false
# 推荐使用 PostHog Project API Key / Project token
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# 兼容旧变量名；如果同时设置，优先使用 NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN
NEXT_PUBLIC_POSTHOG_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_ENABLE_REPLAY=false

# === 支付渠道配置 ===
# 控制哪些支付渠道在用户界面中显示
# 多个渠道用逗号分隔，例如: "paypal,oxapay"
# 如果不设置或设置为空，默认显示所有可用渠道
# 可用值: paypal, oxapay
NEXT_PUBLIC_ENABLED_PAYMENT_PROVIDERS=paypal,oxapay

# 注意：复制此文件为 .env.local 并填入真实凭据
